{
  "manifest_version": 3,
  "name": "Viral Shorts Engine HITL Picker",
  "version": "1.0",
  "description": "Human-in-the-loop asset picker for Google Flow.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "*://labs.google/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://labs.google/*"],
      "css": ["style.css"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Active"
  }
}
