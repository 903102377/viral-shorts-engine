# 必填：用于获取剧本和系统调用的 API Key (大模型)
MINIMAX_API_KEY="your-api-key-here"
MINIMAX_BASE_URL="https://api.minimax.chat/v1"

# 必填：本地浏览器的远程调试端口 (用于劫持 Flow 生图和视频)
# 启动 Chrome 时必须带上参数: --remote-debugging-port=9222
CHROME_CDP_URL="http://127.0.0.1:9222"

# 必填：你在 Google Labs 的项目地址
FLOW_PROJECT_URL="https://labs.google/fx/tools/flow/project/your-project-id"

# 必填：你的短剧数据想要存放的绝对路径（请确保该目录存在）
# 比如: /Users/username/Desktop/短剧项目
WORKSPACE_PATH="/path/to/your/workspace"
