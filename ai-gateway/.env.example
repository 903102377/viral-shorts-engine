# AI Gateway 配置

# 必填：本地浏览器的远程调试端口 (Chrome 启动时需带 --remote-debugging-port=9222)
CHROME_CDP_URL="http://127.0.0.1:9222"

# 可选：API 服务端口 (默认 4100)
PORT=4100

# 可选：简单密钥鉴权 (如果设置了，所有请求头必须带 Authorization: Bearer <此密钥>)
# API_SECRET="your-secret-key"

# 注意：FLOW_PROJECT_URL 不在这里配置！
# 每个调用方项目的 Flow 地址不同，必须在每次请求时通过 flowUrl 参数传入。
